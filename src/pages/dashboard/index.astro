---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
	<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
		<!-- SEA Movement Introduction Card -->
		<div class="mb-12 rounded-3xl bg-linear-to-r from-emerald-500/5 to-teal-500/5 dark:from-emerald-500/5 dark:to-teal-500/5 border border-emerald-500/10 dark:border-slate-800 p-6 sm:p-8 flex flex-col md:flex-row items-center gap-6 shadow-xs">
			<div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-emerald-50 dark:bg-emerald-950/40 text-emerald-600 dark:text-emerald-400 border border-emerald-500/10">
				<i data-lucide="info" class="w-8 h-8"></i>
			</div>
			<div>
				<h2 class="font-outfit text-lg font-bold text-slate-900 dark:text-white mb-2">About SEA Movement & Project ARTEMIS</h2>
				<p class="text-xs text-slate-650 dark:text-slate-450 leading-relaxed">
					<strong>SEA Movement</strong> is a Chennai-based environmental non-profit trust registered in October 2008. We focus on grassroots sustainability, sustainable organic agriculture, mapping water resources, and improving rural livelihoods. 
					This dashboard tracks key ecological indicators (like temperature cooling and water well levels) at our project sites in Ranipet, Nilgiris, and Kanniyakumari, alongside candidates in our SkillGrid skilling program.
				</p>
			</div>
		</div>

		<!-- Page Header -->
		<div class="mb-10 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
			<div>
				<h1 class="font-outfit text-3xl font-extrabold text-slate-900 dark:text-white sm:text-4xl">Ecological & Skilling Impact</h1>
				<p class="text-sm text-slate-600 dark:text-slate-400 mt-2">
					Visualizing live indicators, field telemetry, and youth skilling parameters.
				</p>
			</div>
			
			<!-- Interactive Tab List -->
			<div class="inline-flex gap-2 rounded-2xl bg-slate-100 dark:bg-slate-950 border border-slate-200/60 dark:border-slate-800/85 p-1">
				<button id="tab-ranipet" class="rounded-xl px-4 py-2.5 text-xs font-bold text-emerald-700 dark:text-emerald-450 bg-white dark:bg-slate-900 border border-emerald-500/10 dark:border-emerald-500/20 shadow-xs focus:outline-none transition-all duration-200 flex items-center gap-1.5 cursor-pointer">
					<i data-lucide="tree-deciduous" class="w-3.5 h-3.5"></i>
					Ranipet Food Forest
				</button>
				<button id="tab-water" class="rounded-xl px-4 py-2.5 text-xs font-bold text-slate-550 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 focus:outline-none transition-all duration-200 flex items-center gap-1.5 cursor-pointer">
					<i data-lucide="droplets" class="w-3.5 h-3.5"></i>
					Tribal Housing Water
				</button>
				<button id="tab-skillgrid" class="rounded-xl px-4 py-2.5 text-xs font-bold text-slate-550 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 focus:outline-none transition-all duration-200 flex items-center gap-1.5 cursor-pointer">
					<i data-lucide="briefcase" class="w-3.5 h-3.5"></i>
					SkillGrid Admin Demo
				</button>
			</div>
		</div>

		<!-- CONTENT SECTION 1: RANIPET FOOD FOREST -->
		<div id="content-ranipet" class="space-y-8 animate-fade-in">
			<!-- Banner KPI Highlight -->
			<div class="rounded-3xl bg-linear-to-r from-emerald-50/60 via-teal-50/40 to-slate-50/60 dark:from-emerald-950/20 dark:via-teal-950/10 dark:to-slate-950/20 border border-emerald-500/20 dark:border-emerald-500/30 p-6 sm:p-8 flex flex-col sm:flex-row items-center justify-between gap-6 shadow-xs">
				<div class="space-y-2 text-center sm:text-left">
					<span class="inline-flex items-center rounded-md bg-emerald-50 dark:bg-emerald-950/40 px-2 py-1 text-xs font-bold text-emerald-700 dark:text-emerald-450 ring-1 ring-inset ring-emerald-600/10 dark:ring-emerald-500/20">
						Calculated Cooling Index
					</span>
					<h2 id="cooling-index-headline" class="font-outfit text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white">
						-5.2°C Cooler Than Open Areas
					</h2>
					<p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400">
						Greenera Food Forest demonstrates significant microclimate cooling compared to nearby open fields and standard farms.
					</p>
				</div>
				<div class="flex items-center gap-4 bg-white dark:bg-slate-900 px-6 py-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
					<div class="text-center">
						<span class="block text-[10px] uppercase font-bold tracking-wider text-slate-500 dark:text-slate-400">vs Normal Farm</span>
						<span id="cooling-vs-normal" class="font-outfit font-black text-emerald-600 dark:text-emerald-450 text-2xl">-2.6°C</span>
					</div>
					<div class="h-8 w-px bg-slate-200 dark:bg-slate-800"></div>
					<div class="text-center">
						<span class="block text-[10px] uppercase font-bold tracking-wider text-slate-500 dark:text-slate-400">Forest Moisture</span>
						<span id="live-soil-moisture" class="font-outfit font-black text-teal-600 dark:text-teal-450 text-2xl">28%</span>
					</div>
				</div>
			</div>

			<!-- Main Chart Grid (2x2 Grid of detailed charts) -->
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
				<!-- Temperature Chart Card -->
				<div class="rounded-3xl border border-slate-200/85 dark:border-slate-800 bg-white dark:bg-slate-900/40 p-6 shadow-md flex flex-col">
					<div class="flex items-center justify-between mb-4">
						<div>
							<h3 class="font-outfit text-base font-bold text-slate-900 dark:text-white flex items-center gap-1.5">
								<i data-lucide="thermometer" class="w-4 h-4 text-slate-500"></i>
								Ambient Temperature
							</h3>
							<p class="text-[10px] text-slate-500 dark:text-slate-400">Comparing microclimate shade canopy stability</p>
						</div>
						<span id="temp-delta-badge" class="inline-flex items-center rounded-md bg-emerald-50 dark:bg-emerald-950/40 px-2 py-1 text-[10px] font-bold text-emerald-700 dark:text-emerald-400">-5.2°C Delta</span>
					</div>
					<div class="relative grow min-h-60">
						<canvas id="ranipet-temp-chart"></canvas>
					</div>
				</div>

				<!-- Soil Moisture Chart Card -->
				<div class="rounded-3xl border border-slate-200/85 dark:border-slate-800 bg-white dark:bg-slate-900/40 p-6 shadow-md flex flex-col">
					<div class="flex items-center justify-between mb-4">
						<div>
							<h3 class="font-outfit text-base font-bold text-slate-900 dark:text-white flex items-center gap-1.5">
								<i data-lucide="droplet" class="w-4 h-4 text-slate-500"></i>
								Soil Moisture (0-10cm)
							</h3>
							<p class="text-[10px] text-slate-500 dark:text-slate-400">Water retention and drought resilience</p>
						</div>
						<span id="moisture-delta-badge" class="inline-flex items-center rounded-md bg-teal-50 dark:bg-teal-950/40 px-2 py-1 text-[10px] font-bold text-teal-700 dark:text-teal-400">+23% Delta</span>
					</div>
					<div class="relative grow min-h-60">
						<canvas id="ranipet-moisture-chart"></canvas>
					</div>
				</div>

				<!-- Relative Humidity Chart Card -->
				<div class="rounded-3xl border border-slate-200/85 dark:border-slate-800 bg-white dark:bg-slate-900/40 p-6 shadow-md flex flex-col">
					<div class="flex items-center justify-between mb-4">
						<div>
							<h3 class="font-outfit text-base font-bold text-slate-900 dark:text-white flex items-center gap-1.5">
								<i data-lucide="cloud" class="w-4 h-4 text-slate-500"></i>
								Relative Humidity
							</h3>
							<p class="text-[10px] text-slate-500 dark:text-slate-400">Transpiration and ambient moisture levels</p>
						</div>
						<span id="humidity-delta-badge" class="inline-flex items-center rounded-md bg-blue-50 dark:bg-blue-950/40 px-2 py-1 text-[10px] font-bold text-blue-700 dark:text-blue-400">+26% Delta</span>
					</div>
					<div class="relative grow min-h-60">
						<canvas id="ranipet-humidity-chart"></canvas>
					</div>
				</div>

				<!-- Evapotranspiration Chart Card -->
				<div class="rounded-3xl border border-slate-200/85 dark:border-slate-800 bg-white dark:bg-slate-900/40 p-6 shadow-md flex flex-col">
					<div class="flex items-center justify-between mb-4">
						<div>
							<h3 class="font-outfit text-base font-bold text-slate-900 dark:text-white flex items-center gap-1.5">
								<i data-lucide="sprout" class="w-4 h-4 text-slate-500"></i>
								Evapotranspiration (ET0)
							</h3>
							<p class="text-[10px] text-slate-500 dark:text-slate-400">Est. daily water loss to the atmosphere</p>
						</div>
						<span id="et0-delta-badge" class="inline-flex items-center rounded-md bg-amber-50 dark:bg-amber-950/40 px-2 py-1 text-[10px] font-bold text-amber-700 dark:text-amber-400">-2.7mm Delta</span>
					</div>
					<div class="relative grow min-h-60">
						<canvas id="ranipet-et-chart"></canvas>
					</div>
				</div>
			</div>

			<!-- Detailed Ranipet Forestry Reports & Farmer Guide -->
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
				<!-- Canopy Shading Report -->
				<div class="lg:col-span-2 rounded-3xl border border-slate-200/80 dark:border-slate-800 bg-white dark:bg-slate-900/40 p-6 space-y-4 shadow-xs">
					<div class="flex items-center justify-between">
						<h4 class="font-outfit text-base font-bold text-slate-900 dark:text-white">Canopy Microclimate & Farmer Guidelines</h4>
						<span class="inline-flex items-center rounded-md bg-emerald-50 dark:bg-emerald-950/40 px-2.5 py-0.5 text-[9px] font-bold text-emerald-700 dark:text-emerald-400">Agricultural Advisor</span>
					</div>
					<p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
						By tracking air and canopy temperatures, local farmers can easily monitor **Thermal Crop Stress**. 
						Under extreme heat waves, plants in unshaded fields close their stomata to prevent water loss, which halts photosynthesis and stunts growth. In a multi-tier food forest canopy (Tamarind/Neem shielding Moringa/legumes), the transpirational cooling creates a buffered microclimatic zone.
					</p>
					
					<!-- Farmer Action Box -->
					<div class="rounded-2xl bg-emerald-500/5 dark:bg-emerald-950/20 border border-emerald-500/10 dark:border-emerald-500/20 p-4 space-y-2">
						<h5 class="text-xs font-bold text-emerald-800 dark:text-emerald-400 flex items-center gap-1.5 font-outfit">
							<i data-lucide="book-open" class="w-3.5 h-3.5"></i> Irrigation & Mulching Guide
						</h5>
						<ul class="list-disc pl-4 text-[11px] text-slate-650 dark:text-slate-400 space-y-1">
							<li><strong>Cooling Index Threshold:</strong> If the temperature delta between regional weather (from internet forecast) and your canopy shade thermometer drops below <strong>2.0°C</strong> during the 2:00 PM peak, it triggers an immediate need to irrigate.</li>
							<li><strong>Microclimatic Soil Moisture:</strong> Aim to keep moisture levels above <strong>25%</strong>. A thick 10cm dry-leaf mulch layer keeps soil wet and reduces drip irrigation frequency by 50% compared to un-mulched farms.</li>
						</ul>
					</div>
				</div>

				<!-- Soil Infiltration & Low-Cost Instrument Table -->
				<div class="rounded-3xl border border-slate-200/80 dark:border-slate-800 bg-white dark:bg-slate-900/40 p-6 space-y-6 shadow-xs">
					<div>
						<h4 class="font-outfit text-base font-bold text-slate-900 dark:text-white mb-2">On-Farm Low-Cost Tools</h4>
						<p class="text-[10px] text-slate-500 dark:text-slate-400 leading-relaxed mb-4">
							No expensive internet-of-things (IoT) nodes are required. Farmers can run this monitoring suite using cheap tools:
						</p>
						<div class="overflow-x-auto">
							<table class="w-full text-left text-xs border-collapse">
								<thead>
									<tr class="border-b border-slate-200 dark:border-slate-800 text-[9px] uppercase font-bold text-slate-500 dark:text-slate-400">
										<th class="pb-2">Metric</th>
										<th class="pb-2">Tool</th>
										<th class="pb-2 text-right">Est. Cost</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-slate-100 dark:divide-slate-800 text-[11px] text-slate-650 dark:text-slate-350">
									<tr>
										<td class="py-2.5 font-semibold">Canopy Temp</td>
										<td class="py-2.5">Analog Thermometer</td>
										<td class="py-2.5 text-right font-bold text-emerald-600 dark:text-emerald-450 font-outfit">₹150</td>
									</tr>
									<tr>
										<td class="py-2.5 font-semibold">Soil Moisture</td>
										<td class="py-2.5">Metal Probe Tensiometer</td>
										<td class="py-2.5 text-right font-bold text-emerald-600 dark:text-emerald-450 font-outfit">₹300</td>
									</tr>
									<tr>
										<td class="py-2.5 font-semibold">Water Depth</td>
										<td class="py-2.5">Weighted Tape Measure</td>
										<td class="py-2.5 text-right font-bold text-emerald-600 dark:text-emerald-450 font-outfit">₹100</td>
									</tr>
									<tr>
										<td class="py-2.5 font-semibold">Precipitation</td>
										<td class="py-2.5">Graduated Rain Gauge</td>
										<td class="py-2.5 text-right font-bold text-emerald-600 dark:text-emerald-450 font-outfit">₹150</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>
					
					<!-- Short Infiltration Rate details -->
					<div class="pt-4 border-t border-slate-100 dark:border-slate-800 flex justify-between items-center text-xs">
						<span class="text-slate-500 dark:text-slate-400">Soil Infiltration Rate:</span>
						<span class="font-bold text-emerald-700 dark:text-emerald-450 font-outfit">85 mm/hr (Canopy) vs 8 mm/hr (Open Area)</span>
					</div>
				</div>
			</div>
		</div>

		<!-- CONTENT SECTION 2: GROUNDWATER & LANDSLIDE MONITOR -->
		<div id="content-water" class="space-y-8 hidden animate-fade-in">
			<!-- Early Warning System Indicator -->
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				<!-- Warning Widget -->
				<div class="md:col-span-1 rounded-3xl border border-amber-500/25 dark:border-amber-500/35 bg-amber-50/20 dark:bg-amber-950/20 p-6 flex flex-col justify-between shadow-md">
					<div>
						<span class="inline-flex items-center gap-1 rounded-md bg-amber-100 dark:bg-amber-950/40 px-2.5 py-0.5 text-xs font-extrabold text-amber-800 dark:text-amber-400 ring-1 ring-inset ring-amber-600/10 dark:ring-amber-500/20 mb-4">
							<i data-lucide="alert-triangle" class="w-3.5 h-3.5"></i> Early Warning Level
						</span>
						<h3 class="font-outfit text-xl font-bold text-slate-900 dark:text-white">Nilgiris Landslide Risk</h3>
						<p class="text-xs text-slate-650 dark:text-slate-400 mt-2 leading-relaxed">
							Based on rainfall thresholds (P24 &ge; 50mm).
						</p>
					</div>

					<div class="my-6">
						<!-- Risk Status Gauge Mock -->
						<div class="flex items-center gap-3 bg-white dark:bg-slate-950 p-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-xs">
							<div class="h-3 w-3 rounded-full bg-amber-400 animate-pulse"></div>
							<div>
								<span class="block text-xs font-bold text-slate-800 dark:text-slate-200">Status: ADVISORY</span>
								<span class="block text-[10px] text-slate-500 dark:text-slate-400">Soil is highly saturated</span>
							</div>
						</div>
					</div>

					<p class="text-[10px] text-slate-500 dark:text-slate-450">
						Coordinators check drainage paths. Check dams stability check recommended.
					</p>
				</div>

				<!-- Water statistics banner -->
				<div class="md:col-span-2 rounded-3xl border border-slate-200/85 dark:border-slate-800 bg-white dark:bg-slate-900/40 p-6 flex flex-col justify-between shadow-md">
					<div class="flex items-center justify-between mb-4">
						<h3 class="font-outfit text-lg font-bold text-slate-900 dark:text-white">Kanniyakumari Aquifer Trends</h3>
						<span class="text-xs text-slate-500 dark:text-slate-400">Seeded Weekly logs</span>
					</div>
					
					<div class="relative grow min-h-55">
						<canvas id="water-chart"></canvas>
					</div>
				</div>
			</div>

			<!-- Hydrology Insights -->
			<div class="rounded-3xl border border-slate-200 dark:border-slate-800 bg-slate-50/80 dark:bg-slate-900/60 p-6 shadow-xs">
				<h3 class="font-outfit text-sm font-bold text-slate-900 dark:text-white mb-4">Understanding Groundwater Infiltration</h3>
				<p class="text-xs text-slate-655 dark:text-slate-400 leading-relaxed max-w-4xl">
					By logging groundwater water depth from regional reference points alongside precipitations values, we map the **Aquifer Recharge Rate**. A rising water table (smaller depth-to-water numbers) following rains confirms soil absorption. Flat lines signify high runoff levels, warning of landslide potential.
				</p>
			</div>

			<!-- Detailed Hydrological Reports & Landslide Matrix -->
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
				<!-- Landslide Threshold Warning Matrix Table -->
				<div class="lg:col-span-2 rounded-3xl border border-slate-200/80 dark:border-slate-800 bg-white dark:bg-slate-900/40 p-6 space-y-4 shadow-xs">
					<h4 class="font-outfit text-base font-bold text-slate-900 dark:text-white">Landslide Threshold Warning Matrix (Nilgiris)</h4>
					<div class="overflow-x-auto">
						<table class="w-full text-left text-xs border-collapse">
							<thead>
								<tr class="border-b border-slate-200 dark:border-slate-800 text-[10px] uppercase font-bold text-slate-500 dark:text-slate-400">
									<th class="pb-3 pl-2">Warning Level</th>
									<th class="pb-3">3-Day Cum. Rain</th>
									<th class="pb-3">Soil Moisture Saturation</th>
									<th class="pb-3">Action Protocol</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-slate-100 dark:divide-slate-800 text-slate-650 dark:text-slate-350">
								<tr class="bg-emerald-50/10 dark:bg-emerald-950/5">
									<td class="py-3 pl-2 font-bold text-emerald-600 dark:text-emerald-400 font-outfit">🟢 Normal / Safe</td>
									<td class="py-3">&lt; 30 mm</td>
									<td class="py-3">&lt; 40%</td>
									<td class="py-3">Standard baseline weekly logging.</td>
								</tr>
								<tr class="bg-amber-50/10 dark:bg-amber-950/5">
									<td class="py-3 pl-2 font-bold text-amber-600 dark:text-amber-400 font-outfit">🟡 Advisory</td>
									<td class="py-3">30 – 60 mm</td>
									<td class="py-3">40% – 65%</td>
									<td class="py-3">Alert village coordinators; inspect blockages.</td>
								</tr>
								<tr class="bg-orange-50/10 dark:bg-orange-950/5">
									<td class="py-3 pl-2 font-bold text-orange-600 dark:text-orange-400 font-outfit">🟠 Warning Alert</td>
									<td class="py-3">60 – 100 mm</td>
									<td class="py-3">65% – 85%</td>
									<td class="py-3">Prepare shelter points; trigger daily warnings.</td>
								</tr>
								<tr class="bg-red-50/10 dark:bg-red-950/5">
									<td class="py-3 pl-2 font-bold text-red-600 dark:text-red-400 font-outfit">🔴 Evacuate</td>
									<td class="py-3">&gt; 100 mm</td>
									<td class="py-3">&gt; 85%</td>
									<td class="py-3">Immediate relocation of at-risk settlements.</td>
								</tr>
							</tbody>
						</table>
					</div>
				</div>
				
				<!-- Well Hydro-recharge Analysis -->
				<div class="rounded-3xl border border-slate-200/80 dark:border-slate-800 bg-white dark:bg-slate-900/40 p-6 space-y-4 flex flex-col justify-between shadow-xs">
					<div>
						<h4 class="font-outfit text-base font-bold text-slate-900 dark:text-white mb-2">Aquifer Recharge Dynamics</h4>
						<p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
							In the Kanniyakumari aquifer, we monitor the correlation between coastal rain events and the speed of well-water replenishment. 
						</p>
						<p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed mt-2">
							Sandy loam soils demonstrate quick saturation and rapid water-table bounce. Clayey layers block vertical infiltration, leading to water pooling on the surface and low well recovery.
						</p>
					</div>
					<div class="rounded-2xl bg-blue-50/30 dark:bg-blue-950/20 border border-blue-100/30 p-4 text-[10px] text-blue-700 dark:text-blue-400 mt-4 leading-relaxed font-semibold">
						📌 Hydro-Fact: Healthy root channels in agro-forestry sites act as natural pipelines, speeding up deep aquifer recharge by 400% compared to deforested soil.
					</div>
				</div>
			</div>
		</div>

		<!-- CONTENT SECTION 3: SKILLGRID ADMIN DEMO -->
		<div id="content-skillgrid" class="space-y-8 hidden animate-fade-in">
			<!-- Header Block -->
			<div class="rounded-3xl bg-slate-100/50 dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 p-6">
				<h3 class="font-outfit text-lg font-bold text-slate-900 dark:text-white mb-1">SkillGrid Global Admin Portal Mockup</h3>
				<p class="text-xs text-slate-600 dark:text-slate-400">
					Simulating candidate placements, LMS SCORM progress audits, and automated resume parsing details.
				</p>
			</div>

			<!-- SkillGrid LMS Metrics Cards -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
				<div class="rounded-2xl border border-slate-200/80 dark:border-slate-800 bg-white/50 dark:bg-slate-900/40 p-4 shadow-xs">
					<span class="block text-[10px] uppercase font-bold text-slate-500 dark:text-slate-450">Total Enrolled</span>
					<span class="font-outfit font-black text-xl text-slate-900 dark:text-white">184 Youth</span>
				</div>
				<div class="rounded-2xl border border-slate-200/80 dark:border-slate-800 bg-white/50 dark:bg-slate-900/40 p-4 shadow-xs">
					<span class="block text-[10px] uppercase font-bold text-slate-500 dark:text-slate-455">Completion Rate</span>
