	<script is:inline>
		// Tab Switching Mechanism
		const tabRanipet = document.getElementById('tab-ranipet');
		const tabWater = document.getElementById('tab-water');
		const tabSkillGrid = document.getElementById('tab-skillgrid');

		const contentRanipet = document.getElementById('content-ranipet');
		const contentWater = document.getElementById('content-water');
		const contentSkillGrid = document.getElementById('content-skillgrid');

		// Handle tabs switching styles
		function activateTab(tab) {
			const activeBtn = "rounded-xl px-4 py-2.5 text-xs font-bold text-emerald-700 dark:text-emerald-450 bg-white dark:bg-slate-900 border border-emerald-500/10 dark:border-emerald-500/20 shadow-xs focus:outline-none transition-all duration-200 flex items-center gap-1.5 cursor-pointer";
			const inactiveBtn = "rounded-xl px-4 py-2.5 text-xs font-bold text-slate-550 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 focus:outline-none transition-all duration-200 flex items-center gap-1.5 cursor-pointer";
			
			tabRanipet.className = (tab === 'ranipet') ? activeBtn : inactiveBtn;
			tabWater.className = (tab === 'water') ? activeBtn : inactiveBtn;
			tabSkillGrid.className = (tab === 'skillgrid') ? activeBtn : inactiveBtn;

			contentRanipet.classList.toggle('hidden', tab !== 'ranipet');
			contentWater.classList.toggle('hidden', tab !== 'water');
			contentSkillGrid.classList.toggle('hidden', tab !== 'skillgrid');
		}

		tabRanipet.addEventListener('click', () => activateTab('ranipet'));
		tabWater.addEventListener('click', () => activateTab('water'));
		tabSkillGrid.addEventListener('click', () => activateTab('skillgrid'));

		// Query Parameter parsing route loader
		window.addEventListener('DOMContentLoaded', () => {
			const params = new URLSearchParams(window.location.search);
			const activeTabParam = params.get('tab');
			if (['ranipet', 'water', 'skillgrid'].includes(activeTabParam)) {
				activateTab(activeTabParam);
			} else {
				activateTab('ranipet');
			}
			fetchAndRenderRanipet();
			renderWaterChart();
		});

		// CV Parser UI Mock simulation trigger
		function triggerMockParser() {
			const outputBox = document.getElementById('parser-output');
			outputBox.classList.remove('hidden');
		}

		// --- Chart.js Graphing Rendering Logic ---
		let tempChart = null;
		let moistureChart = null;
		let humidityChart = null;
		let etChart = null;
		let waterChart = null;

		async function fetchAndRenderRanipet() {
			try {
				// Fetch Historical Readings
				const readingsRes = await fetch('http://127.0.0.1:8000/api/readings');
				let labels = ['Jun 06', 'Jun 07', 'Jun 08', 'Jun 09', 'Jun 10', 'Jun 11', 'Jun 12'];
				
				// Historical Temperature data (mock fallbacks)
				let tempBarren = [39.5, 40.2, 38.9, 41.5, 39.8, 40.1, 39.4];
				let tempNormal = [38.2, 39.5, 37.8, 40.1, 38.6, 39.0, 38.4];
				let tempForest = [34.4, 35.6, 33.9, 36.3, 34.8, 35.1, 34.6];

				if (readingsRes.ok) {
					const readings = await readingsRes.json();
					if (readings.length > 0) {
						labels = readings.map(r => new Date(r.timestamp).toLocaleDateString(undefined, {month: 'short', day: 'numeric'}));
						tempBarren = readings.map(r => r.barren_temp);
						tempNormal = readings.map(r => r.normal_temp);
						tempForest = readings.map(r => r.forest_temp);

						// Update main heading with latest cooling index
						const latest = readings[readings.length - 1];
						const coolingIndexHeadline = document.getElementById('cooling-index-headline');
						const coolingVsNormal = document.getElementById('cooling-vs-normal');
						if(coolingIndexHeadline) {
							coolingIndexHeadline.innerText = `-${latest.cooling_index_barren}°C Cooler Than Open Areas`;
						}
						if(coolingVsNormal) {
							coolingVsNormal.innerText = `-${latest.cooling_index_normal}°C`;
						}
					}
				}

				// Derive historical data for other factors based on temperatures to show consistent comparative trends:
				let moistureForest = tempForest.map(t => Math.max(15, Math.round(90 - t * 1.6)));
				let moistureNormal = tempNormal.map(t => Math.max(5, Math.round(70 - t * 1.4)));
				let moistureBarren = tempBarren.map(t => Math.max(1, Math.round(35 - t * 0.8)));

				let humidityForest = tempForest.map(t => Math.max(30, Math.round(180 - t * 3.5)));
				let humidityNormal = tempNormal.map(t => Math.max(20, Math.round(150 - t * 2.8)));
				let humidityBarren = tempBarren.map(t => Math.max(10, Math.round(110 - t * 2.0)));

				let etForest = tempForest.map(t => Math.round((t * 0.12) * 10) / 10);
				let etNormal = tempNormal.map(t => Math.round((t * 0.15) * 10) / 10);
				let etBarren = tempBarren.map(t => Math.round((t * 0.17) * 10) / 10);

				// Render all 4 charts
				renderTempChart(labels, tempBarren, tempNormal, tempForest);
				renderMoistureChart(labels, moistureBarren, moistureNormal, moistureForest);
				renderHumidityChart(labels, humidityBarren, humidityNormal, humidityForest);
				renderEtChart(labels, etBarren, etNormal, etForest);

				// Fetch Live API Data from Open-Meteo for 3 sites
				const weatherRes = await fetch('http://127.0.0.1:8000/api/weather');
				if (weatherRes.ok) {
					const liveData = await weatherRes.json();
					
					if (liveData.forest && liveData.normal && liveData.barren) {
						// Update Moisture Live Indicator
						const liveMoistureElement = document.getElementById('live-soil-moisture');
						if(liveMoistureElement) liveMoistureElement.innerText = `${(liveData.forest.soil_moisture_0_to_1cm * 100).toFixed(1)}%`;
						
						// Update Badges with current latest differences
						const tempDiff = (liveData.barren.temperature_2m - liveData.forest.temperature_2m).toFixed(1);
						const moistDiff = ((liveData.forest.soil_moisture_0_to_1cm - liveData.barren.soil_moisture_0_to_1cm) * 100).toFixed(0);
						const humDiff = (liveData.forest.relative_humidity_2m - liveData.barren.relative_humidity_2m).toFixed(0);
						const etDiff = (liveData.barren.et0_estimate - liveData.forest.et0_estimate).toFixed(1);

						document.getElementById('temp-delta-badge').innerText = `-${tempDiff}°C Delta`;
						document.getElementById('moisture-delta-badge').innerText = `+${moistDiff}% Delta`;
						document.getElementById('humidity-delta-badge').innerText = `+${humDiff}% Delta`;
						document.getElementById('et0-delta-badge').innerText = `-${etDiff}mm Delta`;
					}
				}
			} catch (e) {
				console.error("Failed to fetch backend data", e);
				// Fallback to mock data if backend is unreachable
				const labels = ['Jun 06', 'Jun 07', 'Jun 08', 'Jun 09', 'Jun 10', 'Jun 11', 'Jun 12'];
				renderTempChart(labels, [39.5, 40.2, 38.9, 41.5, 39.8, 40.1, 39.4], [38.2, 39.5, 37.8, 40.1, 38.6, 39.0, 38.4], [34.4, 35.6, 33.9, 36.3, 34.8, 35.1, 34.6]);
				renderMoistureChart(labels, [5, 4, 6, 3, 5, 4, 5], [15, 14, 16, 13, 15, 14, 15], [28, 27, 29, 26, 28, 27, 28]);
				renderHumidityChart(labels, [32, 30, 33, 29, 31, 30, 32], [45, 42, 47, 41, 44, 43, 45], [58, 56, 59, 54, 57, 56, 58]);
				renderEtChart(labels, [6.8, 7.0, 6.7, 7.2, 6.9, 7.0, 6.8], [5.5, 5.7, 5.4, 5.9, 5.6, 5.7, 5.5], [4.1, 4.3, 4.0, 4.5, 4.2, 4.3, 4.1]);
			}
		}

		// --- Individual Chart Render Helpers ---

		function renderTempChart(labels, barren, normal, forest) {
			const ctx = document.getElementById('ranipet-temp-chart').getContext('2d');
			if (tempChart) tempChart.destroy();
			tempChart = new Chart(ctx, {
				type: 'line',
				data: {
					labels: labels,
					datasets: [
						{ label: '🏜️ Open Area', data: barren, borderColor: 'rgba(239, 68, 68, 0.85)', backgroundColor: 'transparent', borderWidth: 2, borderDash: [5, 5], tension: 0.3, pointRadius: 2 },
						{ label: '🌾 Normal Farm', data: normal, borderColor: 'rgba(245, 158, 11, 0.85)', backgroundColor: 'transparent', borderWidth: 2, tension: 0.3, pointRadius: 2 },
						{ label: '🌳 Food Forest', data: forest, borderColor: 'rgba(16, 185, 129, 0.85)', backgroundColor: 'rgba(16, 185, 129, 0.05)', borderWidth: 3.5, tension: 0.3, pointRadius: 3, fill: true }
					]
				},
				options: getChartOptions('°C')
			});
		}

		function renderMoistureChart(labels, barren, normal, forest) {
			const ctx = document.getElementById('ranipet-moisture-chart').getContext('2d');
			if (moistureChart) moistureChart.destroy();
			moistureChart = new Chart(ctx, {
				type: 'line',
				data: {
					labels: labels,
					datasets: [
						{ label: '🏜️ Open Area', data: barren, borderColor: 'rgba(239, 68, 68, 0.85)', backgroundColor: 'transparent', borderWidth: 2, borderDash: [5, 5], tension: 0.3, pointRadius: 2 },
						{ label: '🌾 Normal Farm', data: normal, borderColor: 'rgba(245, 158, 11, 0.85)', backgroundColor: 'transparent', borderWidth: 2, tension: 0.3, pointRadius: 2 },
						{ label: '🌳 Food Forest', data: forest, borderColor: 'rgba(20, 184, 166, 0.85)', backgroundColor: 'rgba(20, 184, 166, 0.05)', borderWidth: 3.5, tension: 0.3, pointRadius: 3, fill: true }
					]
				},
				options: getChartOptions('%')
			});
		}

		function renderHumidityChart(labels, barren, normal, forest) {
			const ctx = document.getElementById('ranipet-humidity-chart').getContext('2d');
			if (humidityChart) humidityChart.destroy();
			humidityChart = new Chart(ctx, {
				type: 'line',
				data: {
					labels: labels,
					datasets: [
						{ label: '🏜️ Open Area', data: barren, borderColor: 'rgba(239, 68, 68, 0.85)', backgroundColor: 'transparent', borderWidth: 2, borderDash: [5, 5], tension: 0.3, pointRadius: 2 },
						{ label: '🌾 Normal Farm', data: normal, borderColor: 'rgba(245, 158, 11, 0.85)', backgroundColor: 'transparent', borderWidth: 2, tension: 0.3, pointRadius: 2 },
						{ label: '🌳 Food Forest', data: forest, borderColor: 'rgba(99, 102, 241, 0.85)', backgroundColor: 'rgba(99, 102, 241, 0.05)', borderWidth: 3.5, tension: 0.3, pointRadius: 3, fill: true }
					]
				},
				options: getChartOptions('%')
			});
		}

		function renderEtChart(labels, barren, normal, forest) {
			const ctx = document.getElementById('ranipet-et-chart').getContext('2d');
			if (etChart) etChart.destroy();
			etChart = new Chart(ctx, {
				type: 'line',
				data: {
					labels: labels,
					datasets: [
						{ label: '🏜️ Open Area', data: barren, borderColor: 'rgba(239, 68, 68, 0.85)', backgroundColor: 'transparent', borderWidth: 2, borderDash: [5, 5], tension: 0.3, pointRadius: 2 },
						{ label: '🌾 Normal Farm', data: normal, borderColor: 'rgba(245, 158, 11, 0.85)', backgroundColor: 'transparent', borderWidth: 2, tension: 0.3, pointRadius: 2 },
						{ label: '🌳 Food Forest', data: forest, borderColor: 'rgba(245, 158, 11, 0.85)', backgroundColor: 'rgba(245, 158, 11, 0.05)', borderWidth: 3.5, tension: 0.3, pointRadius: 3, fill: true }
					]
				},
				options: getChartOptions('mm')
			});
		}

		function getChartOptions(unit) {
			const isDark = document.documentElement.classList.contains('dark');
			return {
				responsive: true,
				maintainAspectRatio: false,
				plugins: {
					legend: {
						position: 'top',
						labels: {
							color: isDark ? '#e2e8f0' : '#475569',
							font: { family: 'Inter', size: 9 },
							boxWidth: 8,
							padding: 8
						}
					}
				},
				scales: {
					x: {
						grid: { color: isDark ? 'rgba(255, 255, 255, 0.08)' : 'rgba(15, 23, 42, 0.03)' },
						ticks: { color: isDark ? '#94a3b8' : '#64748b', font: { family: 'Inter', size: 9 } }
					},
					y: {
						grid: { color: isDark ? 'rgba(255, 255, 255, 0.08)' : 'rgba(15, 23, 42, 0.03)' },
						ticks: { 
							color: isDark ? '#94a3b8' : '#64748b', 
							font: { family: 'Inter', size: 9 },
							callback: function(value) { return value + unit; }
						}
					}
				}
			};
		}

		function renderWaterChart() {
			const ctx = document.getElementById('water-chart').getContext('2d');
			if (waterChart) waterChart.destroy();

			const isDark = document.documentElement.classList.contains('dark');

			waterChart = new Chart(ctx, {
				type: 'line',
				data: {
					labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4', 'Week 5', 'Week 6'],
					datasets: [
						{
							label: 'Rainfall Precipitation (mm)',
							data: [15.2, 42.4, 88.1, 102.5, 30.2, 64.3],
							borderColor: 'rgba(59, 130, 246, 0.85)', // Tailwind blue-500
							backgroundColor: 'rgba(59, 130, 246, 0.15)',
							borderWidth: 2,
							tension: 0.2,
							fill: true,
							yAxisID: 'yRain'
						},
						{
							label: 'Groundwater Depth (m down)',
							data: [13.2, 11.4, 9.1, 7.8, 8.4, 7.6],
							borderColor: 'rgba(16, 185, 129, 0.85)', // Tailwind emerald-500
							backgroundColor: 'transparent',
							borderWidth: 3,
							tension: 0.25,
							pointStyle: 'rectRot',
							yAxisID: 'yDepth'
						}
					]
				},
				options: {
					responsive: true,
					maintainAspectRatio: false,
					plugins: {
						legend: {
							position: 'top',
							labels: {
								color: isDark ? '#e2e8f0' : '#475569',
								font: { family: 'Inter', size: 11 }
							}
						}
					},
					scales: {
						x: {
							grid: { color: isDark ? 'rgba(255, 255, 255, 0.08)' : 'rgba(15, 23, 42, 0.05)' },
							ticks: { color: isDark ? '#94a3b8' : '#475569', font: { family: 'Inter', size: 10 } }
						},
						yRain: {
							type: 'linear',
							position: 'left',
							grid: { color: isDark ? 'rgba(255, 255, 255, 0.08)' : 'rgba(15, 23, 42, 0.05)' },
							ticks: { 
								color: isDark ? '#94a3b8' : '#475569', 
								font: { family: 'Inter', size: 10 },
								callback: function(value) { return value + 'mm'; }
							}
						},
						yDepth: {
							type: 'linear',
							position: 'right',
							grid: { drawOnChartArea: false },
							ticks: { 
								color: isDark ? '#94a3b8' : '#475569', 
								font: { family: 'Inter', size: 10 },
								callback: function(value) { return value + 'm'; }
							},
							// Invert depth scale so higher water levels (smaller numbers) appear at the top
							reverse: true
						}
					}
				}
			});
		}

		// Redraw charts when theme changes
		window.addEventListener('theme-changed', () => {
			fetchAndRenderRanipet();
			renderWaterChart();
		});
	</script>
</Layout>
