---
import logoImg from '../assets/logo.jpg';
---
<!-- Detailed Premium Footer -->
<footer class="border-t border-slate-200/60 dark:border-slate-800/60 bg-white dark:bg-black pt-16 pb-8 text-slate-650 dark:text-slate-400 transition-colors duration-300">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="grid grid-cols-1 gap-12 lg:grid-cols-3">
			
			<!-- Left Column: Brand & Socials -->
			<div class="flex flex-col gap-4">
				<div class="flex items-center gap-2.5">
					<img src={logoImg.src} alt="Artemis Logo" class="h-7 w-7 rounded-md object-contain bg-white border border-slate-100/80 shadow-xs" />
					<span class="font-outfit text-xl font-semibold tracking-wide text-[#2b5a9e] dark:text-[#60a5fa]">
						Artemis
					</span>
				</div>
				<div>
					<span class="inline-flex items-center rounded-md bg-emerald-550/10 dark:bg-emerald-500/10 px-2 py-1 text-[10px] font-bold text-emerald-700 dark:text-emerald-400 ring-1 ring-inset ring-emerald-600/15 dark:ring-emerald-500/20">
						SEA Movement Partner
					</span>
				</div>
				<p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed max-w-sm">
					Empowering climate-resilient community farms and microclimate conservation under the SEA Movement. Built to secure ecological transparency.
				</p>
				
				<!-- Social Media Link Cards -->
				<div class="flex items-center gap-2.5 mt-2">
					<a href="#" aria-label="X/Twitter" class="flex h-9 w-9 items-center justify-center rounded-xl bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 shadow-xs hover:border-slate-800 dark:hover:border-white hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-all duration-300 text-slate-500 dark:text-slate-400">
						<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-twitter"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
					</a>
					<a href="#" aria-label="Instagram" class="flex h-9 w-9 items-center justify-center rounded-xl bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 shadow-xs hover:border-slate-800 dark:hover:border-white hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-all duration-300 text-slate-500 dark:text-slate-400">
						<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
					</a>
					<a href="#" aria-label="LinkedIn" class="flex h-9 w-9 items-center justify-center rounded-xl bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 shadow-xs hover:border-slate-800 dark:hover:border-white hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-all duration-300 text-slate-500 dark:text-slate-400">
						<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
					</a>
					<a href="#" aria-label="GitHub" class="flex h-9 w-9 items-center justify-center rounded-xl bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/60 shadow-xs hover:border-slate-800 dark:hover:border-white hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-all duration-300 text-slate-500 dark:text-slate-400">
						<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
					</a>
				</div>
			</div>

			<!-- Center Column: Newsletter Block -->
			<div class="flex flex-col gap-4 lg:items-center">
				<div class="w-full max-w-sm">
					<h4 class="font-outfit text-xs font-bold uppercase tracking-wider text-slate-450 dark:text-slate-400 mb-1">Stay updated</h4>
					<p class="text-xs text-slate-500 dark:text-slate-450 leading-relaxed mb-4">
						Subscribe to our newsletter for monthly microclimate reports.
					</p>
					
					<form class="flex gap-2 w-full" onsubmit="event.preventDefault(); alert('Subscribed!');">
						<input 
							type="email" 
							placeholder="Enter your email" 
							class="w-full rounded-xl border border-slate-200 dark:border-slate-800 px-4 py-2.5 text-xs bg-slate-50 dark:bg-slate-950/40 backdrop-blur-xs focus:border-slate-850 dark:focus:border-slate-700/80 focus:outline-none shadow-xs transition-all placeholder-slate-400 dark:placeholder-slate-500 text-slate-800 dark:text-slate-200" 
							required 
						/>
						<button 
							type="submit" 
							class="rounded-xl bg-slate-950 dark:bg-white px-4 py-2.5 text-xs font-bold text-white dark:text-slate-950 hover:bg-slate-800 dark:hover:bg-slate-200 transition-all shadow-xs shrink-0 cursor-pointer"
						>
							Subscribe
						</button>
					</form>
				</div>
			</div>

			<!-- Right Column: Navigation Links -->
			<div class="flex flex-col gap-4 lg:items-end">
				<div class="w-full lg:max-w-xs lg:text-left">
					<h4 class="font-outfit text-xs font-bold uppercase tracking-wider text-slate-450 dark:text-slate-400 mb-3">Quick Links</h4>
					<ul class="space-y-3 text-xs font-medium text-slate-650 dark:text-slate-400 flex flex-col lg:items-start pl-4 pt-2">
						<li>
							<a href="/" class="group flex items-center gap-2 hover:text-slate-950 dark:hover:text-white transition-colors duration-200">
								<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 dark:text-slate-500 group-hover:text-slate-950 dark:group-hover:text-white transition-colors"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
								Home Landing Page
							</a>
						</li>
						<li>
							<a href="/dashboard" class="group flex items-center gap-2 hover:text-slate-950 dark:hover:text-white transition-colors duration-200">
								<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 dark:text-slate-500 group-hover:text-slate-950 dark:group-hover:text-white transition-colors"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="10" rx="1"/><rect width="7" height="5" x="3" y="14" rx="1"/></svg>
								Ecological Dashboard
							</a>
						</li>
						<li>
							<a href="/log" class="group flex items-center gap-2 hover:text-slate-950 dark:hover:text-white transition-colors duration-200">
								<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 dark:text-slate-500 group-hover:text-slate-950 dark:group-hover:text-white transition-colors"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M9 12h6"/><path d="M9 16h6"/><path d="M9 8h6"/></svg>
								Volunteer Entry Log
							</a>
						</li>
					</ul>
				</div>
			</div>

		</div>

		<!-- Common Bottom Partition -->
		<hr class="border-slate-200/80 dark:border-slate-800 mt-8 mb-4" />
		
		<div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-center sm:text-left text-[11px] text-slate-500">
			<p>© 2026 Save Earth from Anthropogenic Movement (SEA Movement). All rights reserved.</p>
			<p>Astro 6 + Tailwind CSS v4 + FastAPI + SQLite/Turso</p>
		</div>
	</div>
</footer>
